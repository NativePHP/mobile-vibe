{
    "name": "nativephp/mobile-vibe",
    "description": "Websockets for NativePHP Mobile — live server events (Pusher protocol: Vask / Reverb / Pusher)",
    "type": "nativephp-plugin",
    "license": "MIT",
    "homepage": "https://github.com/nativephp/mobile-vibe",
    "support": {
        "issues": "https://github.com/nativephp/mobile-vibe/issues",
        "source": "https://github.com/nativephp/mobile-vibe"
    },
    "authors": [
        {
            "name": "Bifrost Technology, LLC",
            "email": "support@nativephp.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "nativephp/mobile": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "NativePHP\\Vibe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NativePHP\\Vibe\\VibeServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^2.7|^3.0|^4.0"
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}